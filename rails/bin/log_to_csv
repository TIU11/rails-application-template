#!/usr/bin/env ruby
# frozen_string_literal: true

# Write logged API request details to a CSV. Expects uncompressed files.
#
# Usage:
#     zgrep --no-filename "ms for GET 'http" log/production.log* | bundle exec bin/logshow
#     zcat --force log/production.log* | bundle exec bin/logshow
#     zcat log/production.log-201804{15..21}.gz | bundle exec bin/logshow
#     bundle exec bin/logshow log/production.log
#
# You could download with scp:
# `scp ahoyt@nginxhosting:/export/home/tiu11.org/meds-admin-student-course/current/api_call_summary.csv ~/Downloads/`

require 'csv'
require 'addressable/uri'
require 'active_support/core_ext/hash'
require_relative '../lib/log_analyzer'

LOGS = 'log/production.log*'

HEADERS = %w[timestamp pid severity response_code milliseconds method uri wsfunction].freeze
OUTFILE = 'api_call_summary.csv'
current_file = '-' # ARGF.filename == '-' for STDIN

CSV.open OUTFILE, 'w', headers: HEADERS do |csv|
  csv << HEADERS

  ARGF.each_line do |line|
    puts "Processing #{current_file = ARGF.filename}" unless current_file == ARGF.filename

    # Capture Rails log line
    captures = LogAnalyzer.capture(:rails_base, line)
    next if captures.nil?

    # Excel doesn't understand timezones, but understands strftime('%Y-%m-%d %H:%M:%S.%L')
    captures['timestamp'] = captures['timestamp'].sub('T', ' ')

    # Capture API
    message_captures = LogAnalyzer.capture(:api_request, captures['message'])
    next if message_captures.nil?

    captures.merge! message_captures

    # Capture Moodle API params
    uri = Addressable::URI.parse(captures['uri'])
    captures.merge! uri.query_values.slice('wsfunction')

    puts "#{ARGF.lineno}: #{captures['timestamp']}" # Indicate progress

    csv << captures.values_at(*HEADERS) # Write row to CSV
  end
  puts "Saved #{csv.lineno - 1} api calls out of #{ARGF.lineno} lines to #{OUTFILE}"
end
