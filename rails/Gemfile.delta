gem 'authlogic', '~> 3.1.2' # Authentication
gem 'cancan', '~> 1.6.10'   # Authorization
gem 'will_paginate', '~> 3.0'
gem 'underscore-rails'      # utility-belt library for JavaScript
gem 'dotenv-rails'          # Loads environment variables from .env into ENV, automagically.
gem 'exception_notification', '~> 4.0.1'

RAILS4-
gem 'friendly_id', '~> 5.0.0'
-RAILS4

RAILS3-
gem 'active_model_serializers'
gem 'strong_parameters'
gem 'friendly_id', '~> 4.0.0'
-RAILS3

group :development do
  gem 'capistrano', '~> 2.15.5'
  gem 'rvm-capistrano'

  # Use 'thin' to avoid "Could not determine content-length of response body." warnings.
  # See http://stackoverflow.com/questions/7082364/what-does-warn-could-not-determine-content-length-of-response-body-mean-and-h
  gem 'thin'

  gem 'better_errors'
  gem 'binding_of_caller'
  gem 'rails_best_practices'
  gem 'pry-rails'
end

RAILS3-
# Gems used only for assets and not required
# in production environments by default.
group :assets do
-RAILS3
  gem 'compass-rails'

  # See https://github.com/sstephenson/execjs#readme for more supported runtimes
  gem 'therubyracer', :platforms => :ruby

  gem 'less-rails' # For Twitter Bootstrap
  gem 'twitter-bootstrap-rails'
RAILS3-
end
-RAILS3

group :test, :development do
  gem 'factory_girl_rails'
  gem 'rspec-rails', '~> 2.0'
end

