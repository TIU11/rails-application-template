<!DOCTYPE html>
<html class="<%= @page_class %>" lang="<%= I18n.locale %>">
<head>
  <!-- Release: <%= Rails.root.basename %> -->
  <title><%= title %></title>
  <meta name="description" content="<%= meta_description %>" />
  <%= stylesheet_link_tag    'application', media: 'all' %>
  <%= javascript_include_tag 'application' %>
  <%= csrf_meta_tags %>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= favicon_link_tag "favicon.ico" %>
</head>
<body>
  <div class="container">
    <%= render 'shared/nav' %>

    <div class="row">
      <div class="col-md-12">

        <% if flash[:success] %>
          <p class="alert alert-success" role="alert">
            <%= raw(flash[:success]) %>
          </p>
        <% end %>

        <% if flash[:notice] %>
          <p class="alert alert-info" role="alert">
            <%= raw(flash[:notice]) %>
          </p>
        <% end %>

        <% if flash[:warning] %>
          <p class="alert alert-warning" role="alert">
            <%= raw(flash[:warning]) %>
          </p>
        <% end %>

        <% if flash[:error] %>
          <p class="alert alert-danger" role="alert">
            <%= raw(flash[:error]) %>
          </p>
        <% end %>

        <%= render 'shared/unsupported_browsers' %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12">
        <%= yield %>
      </div>
    </div>
  </div>

  <footer>
    <div class="container">
      <div class="row">
        <div class="col-sm-4 hidden-xs">
          <p>
            <%= image_tag 'tiulogo_titled.png', id: 'footer-logo' %>
          </p>
        </div>
        <div class="col-sm-8">
          <p class="text-muted">
            Copyright &copy; <%= Date.today.year %> <a href="http://www.tiu11.org">Tuscarora Intermediate Unit 11</a><br>
          </p>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>
