<div class="container">
  <div class="row">
    <div class="col-md-12">

      <% if flash[:success] %>
        <p class="alert alert-success" role="alert">
          <%= raw(flash[:success]) %>
        </p>
      <% end %>

      <% if flash[:notice] %>
        <p class="alert alert-info" role="alert">
          <%= raw(flash[:notice]) %>
        </p>
      <% end %>

      <% if flash[:warning] %>
        <p class="alert alert-warning" role="alert">
          <%= raw(flash[:warning]) %>
        </p>
      <% end %>

      <% if flash[:error] %>
        <p class="alert alert-danger" role="alert">
          <%= raw(flash[:error]) %>
        </p>
      <% end %>

      <%= render 'unsupported_browsers' %>
    </div>
  </div>
</div>
