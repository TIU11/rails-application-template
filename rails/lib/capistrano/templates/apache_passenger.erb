<%
  # https://www.phusionpassenger.com/library/config/apache/
  # https://www.phusionpassenger.com/docs/advanced_guides/install_and_upgrade/apache/working_with_the_apache_config_file.html
  # https://cwiki.apache.org/confluence/display/HTTPD/RedirectSSL
  # https://guides.rubyonrails.org/asset_pipeline.html#far-future-expires-header
%>

<VirtualHost *:80>
   ServerName <%= fqdn %>
   Redirect / https://<%= fqdn %>
</VirtualHost>
<VirtualHost *:443>
    ServerName <%= fqdn %>
    DocumentRoot <%= release_path %>/public

    # Phusion Passenger
    # @see (https://www.phusionpassenger.com/library/config/apache/)
    PassengerEnabled on
    # PassengerMinInstances 1
    PassengerRuby <%= passenger_ruby %> # from project root, run `passenger-config --ruby-command`
    RailsEnv <%= fetch(:rails_env) %>

    <Directory <%= release_path %>/public>
        Allow from all
        Options -MultiViews
        Require all granted
    </Directory>

    <Location /assets/>
      # Use of ETag is discouraged when Last-Modified is present
      Header unset ETag
      FileETag None
      # RFC says only cache for 1 year
      ExpiresActive On
      ExpiresDefault "access plus 1 year"
    </Location>

    # Uploads
    # LimitRequestBody 10485760 # 10 MB

    # SSL
    SSLEngine on
    SSLCertificateFile "/etc/ssl/certs/<%= fetch(:top_level_domain) %>.crt"
    SSLCertificateKeyFile "/etc/ssl/private/<%= fetch(:top_level_domain) %>.key"
</VirtualHost>

PassengerPreStart http://<%= fqdn %>
