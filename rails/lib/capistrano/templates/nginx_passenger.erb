server {
    listen         80;
    server_name    <%= fqdn %>;
    root <%= release_path %>/public;
    passenger_enabled on;
    passenger_min_instances 1;
    passenger_ruby <%= passenger_ruby %>; # from project root, run `passenger-config --ruby-command`
    rails_env "<%= fetch(:rails_env) %>";

    location ~ ^/assets/ {
      gzip_static on; # to serve pre-gzipped version for better compression
      expires max;    # Far-future Expiration for static resources
      add_header Cache-Control public;

      add_header ETag "";
      break;
    }
}

