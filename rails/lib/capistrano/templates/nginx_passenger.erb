<%
  # A single HTTP/HTTPS server
  # - http://nginx.org/en/docs/http/configuring_https_servers.html#single_http_https_server
  #
  # For servers with no HTTP, consider a redirect:
  # server {
  #     listen         80;
  #     server_name    example.tiu11.org;
  #     rewrite        ^ https://$server_name$request_uri? permanent;
  # }
%>
server {
    listen         80;
    listen         443 ssl;
    server_name    <%= fqdn %>;
    root <%= release_path %>/public;

    # Phusion Passenger
    # - https://www.phusionpassenger.com/library/config/nginx/
    passenger_enabled on;
    # passenger_min_instances 1;
    passenger_ruby <%= passenger_ruby %>; # from project root, run `passenger-config --ruby-command`
    rails_env "<%= fetch(:rails_env) %>";

    # Rails Asset Pipeline and Webpacker
    # - https://guides.rubyonrails.org/asset_pipeline.html#far-future-expires-header
    # - https://github.com/rails/webpacker/blob/master/docs/deployment.md#nginx
    location ~ ^/(assets|packs)/ {
      gzip_static on; # to serve pre-gzipped version for better compression
      expires max;    # Far-future Expiration for static resources
      add_header Cache-Control public;

      add_header ETag "";
      break;
    }

    # Uploads
    # client_max_body_size 10m;

    # SSL
    ssl_certificate      /etc/ssl/certs/<%= fetch(:top_level_domain) %>.crt;
    ssl_certificate_key  /etc/ssl/private/<%= fetch(:top_level_domain) %>.key;

    # System Maintenance Page
    # - https://github.com/capistrano/maintenance#usage
    error_page 503 @503;

    # Return a 503 error if the maintenance page exists.
    if (-f <%= release_path %>/public/system/maintenance.html) {
      return 503;
    }

    location @503 {
      # Serve static assets if found.
      if (-f $request_filename) {
        break;
      }

      # Set root to the shared directory.
      root <%= release_path %>/public;
      rewrite ^(.*)$ /system/maintenance.html break;
    }
}

passenger_pre_start http://<%= fqdn %>;
