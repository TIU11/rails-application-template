<h2>Change My Password</h2>

<%= form_for @user, url: password_reset_path, html: {class: 'form-horizontal'}, method: :put do |f| %>

  <%= render 'error_messages', target: @user %>

  <div class="form-group">
    <%= f.label :password, class: 'required col-sm-2 control-label' %>
    <div class="col-sm-4">
      <%= f.password_field :password, autocomplete: 'off', class: 'form-control' %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :password_confirmation, class: 'required col-sm-2 control-label' %>
    <div class="col-sm-4">
      <%= f.password_field :password_confirmation, class: 'form-control' %>
    </div>
  </div>

  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-10">
      <%= f.submit "Update my password and log me in", class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>
