<ul class="nav navbar-nav navbar-right">
  <li>
    <%= link_to icon('question-circle', nil, class: 'fa-lg'), "http://help.tiu11.org", title: "TIU Help Desk", target: "_blank", rel: "noopener" %>
  </li>

  <% if current_user %>
    <li class="dropdown">
      <a href="#" class="dropdown-toggle" data-toggle="dropdown">
        <%= icon 'user' %> <%= current_user %>
        <span class="caret"></span>
      </a>
      <ul class="dropdown-menu">
        <li><%= link_to "My Account", account_path %></li>
        <li><%= link_to "Logout", logout_url(redirect_uri: request.path) %></li>
      </ul>
    </li>
  <% else %>
    <li><%= link_to "Login", login_url %></li>
  <% end %>

  <% if su_user %>
    <li>
      <%= link_to unsu_path, class: 'btn btn-warning' do %>
        <%= icon 'sign-out' %> return to <%= su_user %>
      <% end %>
    </li>
  <% end %>

</ul>
