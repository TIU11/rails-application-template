<%= form_for (@user_session ||= UserSession.new), :url => user_session_path do |f| %>
  <%= render 'shared/error_messages', :target => @user_session %>

  <div class="clearfix">
    <%= f.label :username %>
    <div class="input"><%= f.text_field :username %></div>
  </div>
  <div class="clearfix">
    <%= f.label :password %>
    <div class="input">
      <%= f.password_field :password %>
      <span class="help-block"><%= link_to "Forgot your password?", new_password_reset_url %></span>
    </div>
  </div>

  <div class="actions">
    <%= f.submit "Log In", :class => "btn primary" %>
  </div>
<% end %>
