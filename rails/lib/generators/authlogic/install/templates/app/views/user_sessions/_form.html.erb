<%= form_for (@user_session ||= UserSession.new), url: user_session_path, html: {class: "form-horizontal"} do |f| %>

  <%= render 'shared/error_messages', target: @user_session %>

  <div class="form-group">
    <%= f.label :username, class: 'required col-sm-2 control-label' %>
    <div class="col-sm-4">
      <%= f.text_field :username, class: 'form-control' %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :password, class: 'required col-sm-2 control-label' %>
    <div class="col-sm-4">
      <%= f.password_field :password, class: 'form-control' %>
      <span class="help-block"><%= link_to "Forgot your password?", new_password_reset_url %></span>
    </div>
  </div>

  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-10">
      <%= f.submit "Log In", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
