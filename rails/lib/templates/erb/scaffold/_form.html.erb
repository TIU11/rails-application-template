<%%= form_for(@<%= singular_table_name %>, html: {class: "form-horizontal"}) do |f| %>

  <%%= render 'shared/error_messages', target: @<%= singular_table_name %> %>

<% attributes.each do |attribute| -%>
  <div class="form-group">
    <%%= f.label :<%= attribute.name %>, class: 'required col-sm-2 control-label' %>
    <div class="col-sm-3">
      <%%= f.<%= attribute.field_type %> :<%= attribute.name %>, class: 'form-control' %>
    </div>
  </div>
<% end -%>

  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-10">
      <%%= f.submit class: 'btn btn-primary' %>
      <%%= link_back 'Cancel', class: 'btn btn-default' %>
    </div>
  </div>
<%% end %>
