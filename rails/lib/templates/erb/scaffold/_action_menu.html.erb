<%%
  # Does <%= singular_table_name %> have *any* abilities from the menu?
  if [:edit, :show, :delete].index{|ability| can? ability, <%= singular_table_name %>}
    dropdown_class ||= 'btn-mini'
%>
  <div class="btn-group pull-right">
    <a class="btn btn-default dropdown-toggle <%%= dropdown_class %>" data-toggle="dropdown" href="#">
      <%%= icon 'list' %>
      <span class="caret"></span>
    </a>
    <ul class="dropdown-menu" role="menu">
      <!-- dropdown menu links -->
      <%% if can? :show, <%= singular_table_name %> %>
        <li>
          <%%= link_to icon('file', 'Show'), <%= singular_table_name %>_path(<%= singular_table_name %>) %>
        </li>
      <%% end %>
      <%% if can? :edit, <%= singular_table_name %> %>
        <li>
          <%%= link_to icon('pencil', 'Edit'), edit_<%= singular_table_name %>_path(<%= singular_table_name %>) %>
        </li>
      <%% end %>
      <%% if can? :delete, <%= singular_table_name %> %>
        <li>
          <%%= link_to icon('times', 'Destroy'), <%= singular_table_name %>, {data: { :confirm => 'Are you sure?' }, method: :delete} %>
        </li>
      <%% end %>
    </ul>
  </div>
<%% end %>
